{
    "version": "2.2.0",
    "description": "FFUF - 一款高速 Web Fuzzing 工具",
    "homepage": "https://github.com/ffuf/ffuf",
    "license": "MIT",
    "notes": [
        "FFUF (Fuzz Faster U Fool) 是一款高性能的 Web Fuzzing 工具：",
        "- 支持多种 Fuzzing 模式",
        "- 可配置过滤规则",
        "- 支持多线程",
        "- 可自定义请求头和认证",
        "",
        "基础用法示例：",
        "ffuf -w wordlist.txt -u https://example.com/FUZZ",
        "",
        "详细文档：https://github.com/ffuf/ffuf#usage"
    ],
    "architecture": {
        "32bit": {
            "url": "https://github.com/ffuf/ffuf/releases/download/v2.2.0/ffuf_2.2.0_windows_386.zip",
            "hash": "95e4856d6d004e11e1c98fd065fb93ff4b1101c3466ac8bc672956db201bd998"
        },
        "64bit": {
            "url": "https://github.com/ffuf/ffuf/releases/download/v2.2.0/ffuf_2.2.0_windows_amd64.zip",
            "hash": "32d0aa8d077c9b380ee277015563004ac29005b1e750f3972de26e409e1fdcac"
        }
    },
    "bin": "ffuf.exe",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config\")) {",
        "    New-Item -Path \"$persist_dir\\config\" -ItemType Directory | Out-Null",
        "}"
    ],
    "persist": "config",
    "checkver": {
        "github": "https://github.com/ffuf/ffuf",
        "regex": "releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://github.com/ffuf/ffuf/releases/download/v$version/ffuf_$version_windows_386.zip"
            },
            "64bit": {
                "url": "https://github.com/ffuf/ffuf/releases/download/v$version/ffuf_$version_windows_amd64.zip"
            }
        }
    }
}
