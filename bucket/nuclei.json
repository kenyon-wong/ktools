{
    "version": "3.11.0",
    "description": "Nuclei - Fast and customizable vulnerability scanner based on simple YAML based DSL",
    "homepage": "https://github.com/projectdiscovery/nuclei",
    "license": "MIT",
    "notes": [
        "Basic usage:",
        "nuclei -u https://example.com                    # Scan single URL",
        "nuclei -l urls.txt                               # Scan multiple URLs",
        "nuclei -u https://example.com -t cves/           # Scan with CVE templates",
        "",
        "Template management:",
        "nuclei -update-templates                         # Update templates",
        "nuclei -tl                                       # List templates",
        "",
        "Advanced options:",
        "nuclei -u https://example.com -severity critical,high",
        "nuclei -u https://example.com -tags cve,rce",
        "",
        "Documentation: https://docs.projectdiscovery.io/tools/nuclei/overview"
    ],
